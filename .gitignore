# Python bytecode and caches
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# Build and packaging artifacts
build/
dist/
site/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches and test artifacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.hypothesis/

# IDE/editor settings
.vscode/
.idea/

# Local environment files
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Local datasets and generated data
data/raw/*
data/processed/*
data/scheduler_processed/*
data/reports/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/scheduler_processed/.gitkeep
!data/reports/.gitkeep
*.csv
*.parquet

# Training outputs, checkpoints, and reports
outputs/classifier/*
outputs/scheduler/*
outputs/figures/*
!outputs/classifier/.gitkeep
!outputs/scheduler/.gitkeep
!outputs/figures/.gitkeep
*.pt
*.pth
*.ckpt
*_report.json
*.png
pytest-temp-*/
# Notebook checkpoints
.ipynb_checkpoints/

